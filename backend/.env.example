# ================================================================
# Copy this file to ".env" and fill in your real values.
#   cp .env.example .env
# ================================================================

# --- Groq (get a FREE key at https://console.groq.com/keys) ---
GROQ_API_KEY=gsk_your_groq_api_key_here

# Primary model required by the assignment.
# If gemma2-9b-it struggles with tool-calling on your account,
# switch to llama-3.3-70b-versatile (also allowed by the assignment).
GROQ_MODEL=gemma2-9b-it

# --- PostgreSQL ---
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hcp_crm

# --- CORS (frontend dev server) ---
FRONTEND_ORIGIN=http://localhost:5173
